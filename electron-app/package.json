{
  "name": "video2text-desktop",
  "version": "1.0.0",
  "description": "Video2Text - Standalone desktop app for video-to-text transcription using Whisper AI. Bundles backend + frontend for full local processing.",
  "main": "main.js",
  "scripts": {
    "start": "NODE_OPTIONS='' electron .",
    "dev": "cd ../frontend && NEXT_EXPORT=true NEXT_PUBLIC_API_BASE=http://localhost:8000 npm run build && cd ../electron-app && electron .",
    "build:frontend": "cd ../frontend && NEXT_EXPORT=true NEXT_PUBLIC_API_BASE=http://localhost:8000 npm run build",
    "build": "npm run build:frontend && electron-builder",
    "pack": "npm run build:frontend && electron-builder --dir",
    "dist": "npm run build:frontend && electron-builder",
    "dist:mac": "npm run build:frontend && electron-builder --mac",
    "dist:win": "npm run build:frontend && electron-builder --win",
    "dist:linux": "npm run build:frontend && electron-builder --linux"
  },
  "build": {
    "appId": "com.video2text.desktop",
    "productName": "Video2Text",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "splash.html",
      "package.json",
      "node_modules/serve-handler/**/*",
      "node_modules/mime-types/**/*",
      "node_modules/mime-db/**/*",
      "node_modules/path-is-inside/**/*",
      "node_modules/path-to-regexp/**/*",
      "node_modules/range-parser/**/*",
      "node_modules/content-disposition/**/*",
      "node_modules/safe-buffer/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!__pycache__/**",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!tests/**",
          "!db.sqlite3",
          "!uploads/**",
          "!transcripts/**",
          "!.playwright_profile/**",
          "!notebooklm.py",
          "!browser.py"
        ]
      },
      {
        "from": "../frontend/out",
        "to": "frontend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "serve-handler": "^6.1.6"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  }
}